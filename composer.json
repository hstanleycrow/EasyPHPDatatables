{
    "name": "hstanleycrow/easyphpdatatables",
    "description": "Standalone PHP server-side processing engine for DataTables.net: query, paginate, filter and order from a single PHP table definition.",
    "keywords": [
        "php",
        "datatables",
        "server-side",
        "pagination",
        "pdo",
        "mysql"
    ],
    "license": "MIT",
    "homepage": "https://github.com/hstanleycrow/EasyPHPDatatables",
    "authors": [
        {
            "name": "Harold Rivas AKA Harold Crow",
            "email": "holamundo@microaplicaciones.com",
            "homepage": "https://www.microaplicaciones.com/",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.2",
        "ext-pdo": "*",
        "ext-json": "*"
    },
    "autoload": {
        "psr-4": {
            "hstanleycrow\\EasyPHPDatatables\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "hstanleycrow\\EasyPHPDatatables\\Tests\\Fixtures\\": "tests/Fixtures/",
            "hstanleycrow\\DatatablesDefinitions\\": "DatatablesDefinitions/",
            "hstanleycrow\\Components\\": "Components/"
        }
    },
    "require-dev": {
        "vlucas/phpdotenv": "^5.6",
        "hstanleycrow/easyphpwebcomponents": "^1.0.0",
        "phpunit/phpunit": "^10.4"
    },
    "config": {
        "allow-plugins": {
            "php-http/discovery": true
        }
    }
}
